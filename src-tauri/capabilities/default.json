{
  "$schema": "https://schema.tauri.app/config/2/capability.json",
  "identifier": "default",
  "description": "Default capability for the homelab dashboard",
  "platforms": ["linux", "macOS", "windows"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "log:default",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
