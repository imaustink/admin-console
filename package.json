{
  "name": "homelab-dashboard",
  "version": "1.0.0",
  "description": "Unified dashboard for Kubernetes and Unifi management",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "test-mode": "TEST_MODE=true npm start",
    "build:rpi": "npm run build && electron-builder --linux --arm64",
    "package:rpi": "./build-rpi.sh",
    "deploy:rpi": "./deploy-rpi.sh"
  },
  "keywords": [
    "kubernetes",
    "unifi",
    "dashboard",
    "homelab"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.6",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@kubernetes/client-node": "^0.20.0",
    "axios": "^1.6.5",
    "winston": "^3.11.0"
  },
  "build": {
    "appId": "com.homelab.dashboard",
    "productName": "Homelab Dashboard",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "index.html",
      "styles.css",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "dir",
          "arch": ["arm64"]
        }
      ],
      "category": "System"
    }
  }
}
